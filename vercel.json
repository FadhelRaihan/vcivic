{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.6.2"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build"
        }
    ],
    "headers": [
        {
            "source": "/(build|storage)/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "routes": [
        {
            "src": "/(build|storage)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*\\.(?:png|jpg|jpeg|gif|svg|ico|css|js|txt|woff|woff2|ttf|eot))$",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}